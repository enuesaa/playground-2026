{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "cloudflare-browser-run-try",
	"main": "src/index.ts",
	"compatibility_date": "2026-07-09",
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"compatibility_flags": [
		"nodejs_compat"
	],
	"browser": {
		"binding": "BROWSER"
	}
}