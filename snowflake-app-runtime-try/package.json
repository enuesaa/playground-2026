{
  "name": "my-nextjs-template",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "rm -rf .next && next dev",
    "build": "rm -rf .next dist && next build",
    "start": "next start",
    "format": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "next": "^16.2.7",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "tailwindcss": "^4.2.2",
    "typescript": "6.0.2"
  },
  "prettier": {
    "printWidth": 120,
    "tabWidth": 2,
    "useTabs": false,
    "semi": false,
    "singleQuote": true,
    "jsxSingleQuote": true,
    "endOfLine": "lf"
